# ═══════════════════════════════════════════════════════════
# QA Nexus — Frontend Environment Variables
# ═══════════════════════════════════════════════════════════

# Mock Data Flag: true = local mock data, false = real backend API calls
VITE_USE_MOCK_DATA=false

# API / WebSocket URLs
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# Real-time pipeline log streaming via WebSocket
VITE_ENABLE_WS_STREAMING=false
