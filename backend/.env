# ─────────────────────────────────────────────────────
# QA Nexus Backend — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────

# ── Server ──
APP_ENV=development
APP_PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:5190"]

# ── LLM Provider Flags ──
# Set the active provider: "ollama" | "openai" | "anthropic" | "groq" | "google" | "azure_openai" | "bedrock" | "mock"
LLM_DEFAULT_PROVIDER=ollama

# Two-tier LLM strategy (like TradingAgents deep_think / quick_think)
# deep = judges & critical decisions, quick = workers & analysts
# LLM_DEEP_PROVIDER=anthropic
# LLM_QUICK_PROVIDER=groq

# Per-agent provider overrides (optional — falls back to tier → default)
# Format: AGENT_{AGENT_ID}_PROVIDER=provider_name
# AGENT_STORY_PROVIDER=anthropic
# AGENT_STRATEGY_PROVIDER=openai
# AGENT_WRITER_PROVIDER=anthropic
# AGENT_AUTOMATION_PROVIDER=anthropic
# AGENT_BUG_PROVIDER=openai
# AGENT_COVERAGE_PROVIDER=anthropic
# AGENT_CRITIC_PROVIDER=groq
# AGENT_ADVOCATE_PROVIDER=groq
# AGENT_SUMMARIZER_PROVIDER=anthropic

# ── Debate Configuration ──
DEBATE_MAX_ROUNDS=3
RISK_DEBATE_MAX_ROUNDS=2
DEBATE_TEMPERATURE=0.8

# ── LLM Retry / Fallback ──
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_DELAY=1.0
LLM_FALLBACK_PROVIDERS=["anthropic","openai","ollama"]

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Anthropic ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Groq ──
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Google AI Studio (Gemini) ──
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# ── Azure OpenAI ──
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=              # https://<resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=            # your deployment name
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── AWS Bedrock ──
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
BEDROCK_REGION=us-east-1
BEDROCK_ACCESS_KEY=                  # or use BEDROCK_PROFILE for CLI auth
BEDROCK_SECRET_KEY=
BEDROCK_PROFILE=                     # AWS CLI profile name (alternative to keys)

# ── Execution ──
EXECUTION_PARALLEL_WORKERS=4
EXECUTION_TIMEOUT_MS=30000
EXECUTION_RETRIES=2
EXECUTION_HEADLESS=true

# ── Database ──
DB_URL=sqlite+aiosqlite:///data/qa_nexus.db

# ── Workspace (generated test files) ──
WORKSPACE_DIR=./workspace

# ── Jira Integration ──
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ── GitHub Integration ──
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# ── Slack Notifications ──
SLACK_WEBHOOK_URL=

# ── Email / SMTP Notifications ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=[]
