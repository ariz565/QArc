# ═══════════════════════════════════════════════════════════
# QA Nexus — Frontend Environment Variables
# Copy to .env and adjust as needed
# ═══════════════════════════════════════════════════════════

# ─── Mock Data Flag ───────────────────────────────────────
# true  → Uses local mock data, no backend required
# false → Makes real API calls to the backend
VITE_USE_MOCK_DATA=true

# ─── API / WebSocket URLs ────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# ─── WebSocket Streaming ────────────────────────────────
# Enable real-time pipeline log streaming via WebSocket
VITE_ENABLE_WS_STREAMING=false

# ─── Integrations (optional) ────────────────────────────
# VITE_JIRA_BASE_URL=
# VITE_JIRA_PROJECT_KEY=PROJ
# VITE_GITHUB_REPO_URL=
# VITE_SLACK_WEBHOOK_URL=
